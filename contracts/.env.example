# Copy to .env and fill in real values. Never commit the real .env file.

# ── Wallet / Signer ───────────────────────────────────────────────
# Deployer private key — used for all network transactions
DEPLOYER_PRIVATE_KEY=0xYourPrivateKeyHere

# ── RPC Endpoints ─────────────────────────────────────────────────
# Alchemy / Infura / QuickNode Sepolia URL
RPC_URL_SEPOLIA=https://eth-sepolia.g.alchemy.com/v2/YourAlchemyKey
# Alchemy / Infura / QuickNode mainnet URL
RPC_URL_MAINNET=https://eth-mainnet.g.alchemy.com/v2/YourAlchemyKey

# ── Etherscan (verify.js) ─────────────────────────────────────────
ETHERSCAN_API_KEY=YourEtherscanApiKey

# ── Deploy (deploy.js) ────────────────────────────────────────────
# IPFS URI for the pre-reveal placeholder metadata JSON
UNREVEALED_URI=ipfs://QmYourUnrevealedCID/unrevealed.json

# ── After deploy: populated by deploy.js output ───────────────────
CONTRACT_ADDRESS=0xYourDeployedContractAddress

# ── Presale (set-presale.js) ───────────────────────────────────────
# Path to JSON array of allowlisted addresses (see allowlist.json)
ALLOWLIST_PATH=./allowlist.json

# ── Reserve Mint (reserve-mint.js) ────────────────────────────────
# Wallet / Gnosis Safe that receives the 250 reserve tokens
RESERVE_RECIPIENT=0xYourTreasuryOrGnosisSafeAddress
RESERVE_QUANTITY=250

# ── Reveal (reveal.js) ────────────────────────────────────────────
# IPFS folder URI — trailing slash required
BASE_URI=ipfs://QmYourRevealedFolderCID/

# ── DAO Handoff (dao-handoff.js) ──────────────────────────────────
DAO_ADDRESS=0xYourGnosisSafeAddress
# Safety guard: must be "yes" to execute the irreversible handoff
CONFIRM_HANDOFF=yes
