{
  "name": "momo-candie-contracts",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "compile":      "hardhat compile",
    "test":         "hardhat test",
    "deploy":       "hardhat run scripts/deploy.js --network mainnet",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "verify":       "hardhat run scripts/verify.js --network mainnet",
    "set-presale":  "hardhat run scripts/set-presale.js --network mainnet",
    "set-public":   "hardhat run scripts/set-public.js --network mainnet",
    "reserve-mint": "hardhat run scripts/reserve-mint.js --network mainnet",
    "reveal":       "hardhat run scripts/reveal.js --network mainnet",
    "dao-handoff":  "hardhat run scripts/dao-handoff.js --network mainnet"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "merkletreejs": "^0.4.0",
    "keccak256": "^1.0.6"
  }
