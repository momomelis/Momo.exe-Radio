{
  "name": "momo-candie-contracts",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "precompile":     "node scripts/precompile.js",
    "compile":        "hardhat compile",
    "test":           "hardhat test",
    "deploy:local":   "UNREVEALED_URI=ipfs://placeholder/unrevealed.json hardhat run --no-compile scripts/deploy.js --network hardhat",
    "deploy":         "hardhat run --no-compile scripts/deploy.js --network mainnet",
    "deploy:sepolia": "hardhat run --no-compile scripts/deploy.js --network sepolia",
    "verify":         "hardhat run --no-compile scripts/verify.js --network mainnet",
    "set-presale":    "hardhat run --no-compile scripts/set-presale.js --network mainnet",
    "set-public":     "hardhat run --no-compile scripts/set-public.js --network mainnet",
    "reserve-mint":   "hardhat run --no-compile scripts/reserve-mint.js --network mainnet",
    "reveal":         "hardhat run --no-compile scripts/reveal.js --network mainnet",
    "dao-handoff":    "hardhat run --no-compile scripts/dao-handoff.js --network mainnet"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "merkletreejs": "^0.4.0",
    "keccak256": "^1.0.6"
  }
}
