# Copy this file to .env and fill in your API keys.

# ── Frontend (Vite build-time, safe to treat as rate-limited public key) ──
# Get a free key at https://etherscan.io/apis
VITE_ETHERSCAN_API_KEY=YourEtherscanApiKey

# ── Backend (server/index.js — keep this SECRET, never commit) ──────────
# Get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-YourAnthropicApiKey

# ── Contract (pre-populate Admin panel address field) ─────────────
VITE_CONTRACT_ADDRESS=0xYourDeployedContractAddress
